{
  "name": "jji-notifier",
  "version": "1.1.0",
  "description": "",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "admin": "cd admin && pnpm dev",
    "skills:mine": "tsx --env-file .env scripts/mine-skills.ts",
    "notify:test:enqueue": "tsx --env-file .env scripts/enqueue-notify-test.ts",
    "deploy": "gh workflow run deploy.yml --repo harnyk/jji-notifier --ref $(git rev-parse --abbrev-ref HEAD)"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.28.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.5.0",
    "@types/pino": "^7.0.5",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "aws-embedded-metrics": "^4.2.0",
    "chalk": "^5.6.2",
    "inversify": "^8.1.0",
    "luxon": "^3.7.2",
    "mongoose": "^9.3.0",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2"
  }
}
